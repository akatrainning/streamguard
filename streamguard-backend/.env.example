# StreamGuard 后端配置文件
# 复制此文件为 .env 并填入实际的 API Key

# OpenAI API Key (从 https://platform.openai.com/api-keys 获取)
OPENAI_API_KEY=sk-your-api-key-here

# 后端服务器配置（可选）
# BACKEND_HOST=0.0.0.0
# BACKEND_PORT=8000

# 抖音直播间 ID（可选，用于接入真实直播）
# DOUYIN_ROOM_ID=123456789
# 搜索时是否显示浏览器窗口（默认 0 = 无头模式，不弹窗）
# 调试时可设为 1 以便观察浏览器行为
# DOUYIN_SHOW_BROWSER=0