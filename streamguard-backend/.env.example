# StreamGuard backend configuration

# LLM provider. Default is deepseek, so system OPENAI_API_KEY will not be used
# unless you explicitly set LLM_PROVIDER=openai.
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-flash

# Optional cloud ASR via OpenAI Whisper. Leave empty to use local faster-whisper.
# ASR_OPENAI_API_KEY=sk-your-openai-api-key
# ASR_BASE_URL=

# Local Whisper tuning
LOCAL_WHISPER_MODEL=tiny
WHISPER_CPU_THREADS=2
WHISPER_BEAM_SIZE=1
AUDIO_CAPTURE_IDLE=2
AUDIO_CAPTURE_WINDOW_SECS=5

# Live room audio transcription is CPU/RAM heavy. Keep it disabled unless needed.
ENABLE_LIVE_AUDIO_ASR=1

# Douyin browser automation
DOUYIN_SHOW_BROWSER=0
